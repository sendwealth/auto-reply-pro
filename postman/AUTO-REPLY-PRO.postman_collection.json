                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"wechat\",\n  \"message\": \"企业微信测试消息\",\n  \"recipient\": \"user_id\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/message",
              "host": ["{{base_url}}"],
              "path": ["api", "message"]
            },
            "description": "发送消息到企业微信"
          },
          "response": []
        },
        {
          "name": "Send Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"email\",\n  \"message\": \"这是一封测试邮件\",\n  \"recipient\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/message",
              "host": ["{{base_url}}"],
              "path": ["api", "message"]
            },
            "description": "发送邮件"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Chat with AI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"你好，请介绍一下产品功能\",\n  \"userId\": \"user-123\"\n}"
            },
            "url": {
