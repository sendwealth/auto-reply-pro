              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"feishu\",\n  \"message\": \"测试消息 - 来自Auto-Reply Pro\",\n  \"recipient\": \"ou_xxx\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/message",
              "host": ["{{base_url}}"],
              "path": ["api", "message"]
            },
            "description": "发送消息到飞书"
          },
          "response": []
        },
        {
