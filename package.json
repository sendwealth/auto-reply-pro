{
  "name": "auto-reply-pro",
  "version": "1.0.0",
  "description": "AI驱动的智能消息平台 - 支持飞书、企业微信、邮件、Discord、Web Chat",
  "main": "src/index-secure.js",
  "scripts": {
    "start": "node src/index-secure.js",
    "start:basic": "node src/index.js",
    "start:full": "node src/index-full.js",
    "test": "node tests/core.test.js",
    "test:functional": "node tests/functional/comprehensive-test.js",
    "test:performance": "node tests/performance/performance-test.js",
    "test:security": "node tests/security/security-test.js",
    "test:integration": "node tests/integration/api.test.js",
    "test:all": "npm test && npm run test:functional && npm run test:performance && npm run test:security",
    "test:coverage": "nyc npm run test:all",
    "coverage:report": "nyc report --reporter=html",
    "check": "node scripts/check-env.js",
    "deploy": "./scripts/deploy.sh",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "ai",
    "chatbot",
    "auto-reply",
    "messaging",
    "feishu",
    "wechat",
    "discord",
    "email",
    "automation"
  ],
  "author": "AI CEO",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "axios": "^1.13.6",
    "discord.js": "^14.25.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nyc": "^18.0.0",
    "prom-client": "^15.1.3",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sendwealth/auto-reply-pro.git"
  },
  "bugs": {
    "url": "https://github.com/sendwealth/auto-reply-pro/issues"
  },
  "homepage": "https://github.com/sendwealth/auto-reply-pro#readme"
}
